# Copy this file to .env.local and fill in any overrides.
# .env.local is gitignored — never commit secrets.

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_BASE=https://wilds.mhdb.io/en
VITE_API_VERSION_URL=https://wilds.mhdb.io/version

# ── Community backend (Spec 06/07) ────────────────────────────────────────────
# Dev: point at local Hono server (npm run dev in wilds-hub-api)
# Prod: your VPS URL, e.g. https://api.yourwildshub.com
VITE_COMMUNITY_API_BASE=http://localhost:3000

# ── Future secrets (add to GitHub Actions Secrets, not here) ─────────────────
# VITE_ANALYTICS_ID=
# VITE_SENTRY_DSN=
